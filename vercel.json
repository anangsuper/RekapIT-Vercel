{
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.9.0" },
    "api/login.php": { "runtime": "vercel-php@0.9.0" },
    "api/logout.php": { "runtime": "vercel-php@0.9.0" },
    "api/telegram_webhook.php": { "runtime": "vercel-php@0.9.0" },
    "api/telegram_add_asset.php": { "runtime": "vercel-php@0.9.0" },
    "api/migrate_mysql_to_sheets.php": { "runtime": "vercel-php@0.9.0" },
    "api/broadcast_maintenance_schedule.php": { "runtime": "vercel-php@0.9.0" },
    "api/excel.php": { "runtime": "vercel-php@0.9.0" },
    "api/maintenance_excel.php": { "runtime": "vercel-php@0.9.0" },
    "api/maintenance_pdf.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    {
      "src": "/test_db.php",
      "dest": "/api/index.php"
    },
    {
      "src": "/(assets|uploads)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/export/maintenance_pdf.php",
      "dest": "/api/maintenance_pdf.php"
    },
    {
      "src": "/export/maintenance_excel.php",
      "dest": "/api/maintenance_excel.php"
    },
    {
      "src": "/export/excel.php",
      "dest": "/api/excel.php"
    },
    {
      "src": "/api/(dashboard_data|generate_asset_code|sync|health|test_db)\\.php",
      "dest": "/api/index.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/login.php",
      "dest": "/api/login.php"
    },
    {
      "src": "/logout.php",
      "dest": "/api/logout.php"
    },
    {
      "src": "/health.php",
      "dest": "/api/index.php"
    },
    {
      "src": "/migrate_mysql_to_sheets.php",
      "dest": "/api/migrate_mysql_to_sheets.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
