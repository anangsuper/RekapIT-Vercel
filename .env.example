# =========================================================================
# Rekap IT - Environment Configuration Template
# Salin file ini menjadi '.env' dan sesuaikan nilainya.
# =========================================================================

# ID Google Spreadsheet yang digunakan untuk sinkronisasi database
GOOGLE_SPREADSHEET_ID="YOUR_SPREADSHEET_ID_HERE"

# URL Web App hasil deploy Google Apps Script (api bridge)
# Opsional: Jika menggunakan script bawaan, deploy file 'database/google_apps_script.js'
GOOGLE_SHEET_WEBAPP_URL="https://script.google.com/macros/s/AKfycbysMXyw48D4STuA8cOc-hwOlWgWoltjSaT04W-ouuI4Gs10qXE9ioTgOj3Bzx32q0eDKQ/exec"

# (Opsional) Jika tidak ingin meletakkan file service-account.json secara fisik di server,
# Anda bisa menyalin seluruh konten JSON service account key Anda ke variabel di bawah:
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'

# Token Keamanan untuk webhook sinkronisasi otomatis dari Google Sheets
WEBHOOK_TOKEN="rekap_it_sync_secret_token_123"
